# Copy this to .env.local and fill in your values
# Get these from Firebase Console > Project Settings > Your Apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# NOTE: VITE_FIREBASE_STORAGE_BUCKET is intentionally omitted.
# This app uses Firestore only and runs 100% on Firebase's free Spark plan.

# Optional: Anthropic API key for Claude Vision receipt parsing (more accurate OCR)
# Leave blank to use free Tesseract.js OCR instead.
VITE_ANTHROPIC_API_KEY=
