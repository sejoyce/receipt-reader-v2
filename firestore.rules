// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
//
// These rules allow open read/write for development.
// For production, consider adding Firebase Authentication
// and locking down to authenticated users only.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // For development: open access
    // TODO: replace with auth-gated rules before sharing publicly
    match /{document=**} {
      allow read, write: if true;
    }

    // Production example (requires Firebase Auth):
    // match /{document=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
